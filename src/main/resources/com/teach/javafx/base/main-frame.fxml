<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teach.javafx.controller.base.MainFrameController"
            styleClass="app-shell">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="app-topbar">
            <padding>
                <Insets bottom="14.0" left="24.0" right="24.0" top="14.0" />
            </padding>
            <children>
                <ImageView fitHeight="58.0" fitWidth="58.0" pickOnBounds="true" preserveRatio="true" styleClass="topbar-logo">
                    <image>
                        <Image url="@../picture/oes-logo.png" />
                    </image>
                </ImageView>
                <VBox spacing="3.0">
                    <children>
                        <Label text="OES 在线考试系统" styleClass="app-title" />
                        <Label fx:id="systemPrompt" text="正在连接服务..." styleClass="app-subtitle" />
                    </children>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="3.0">
                    <children>
                        <Label fx:id="welcomeLabel" text="你好" styleClass="user-title" />
                        <Label fx:id="roleLabel" text="ROLE" styleClass="user-role" />
                    </children>
                </VBox>
                <Button onAction="#onLogoutButtonClick" text="退出" styleClass="ghost-button" />
            </children>
        </HBox>
    </top>
    <left>
        <VBox prefWidth="268.0" spacing="14.0" styleClass="sidebar-panel">
            <padding>
                <Insets bottom="20.0" left="18.0" right="18.0" top="20.0" />
            </padding>
            <children>
                <Label text="功能导航" styleClass="sidebar-title" />
                <Label text="选择一个模块，在右侧工作区继续操作。" styleClass="sidebar-caption" wrapText="true" />
                <TreeView fx:id="menuTree" VBox.vgrow="ALWAYS" styleClass="menu-tree" />
                <Label text="OES v1.0 · ShanDong University" styleClass="sidebar-footer" />
            </children>
        </VBox>
    </left>
    <center>
        <StackPane styleClass="content-shell">
            <children>
                <TabPane fx:id="contentTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="content-tabs" />
            </children>
        </StackPane>
    </center>
</BorderPane>
